# BCELP Backend environment example

APP_NAME=BCELP Backend
APP_VERSION=0.1.0
ENVIRONMENT=development

POSTGRES_USER=bcelp_user
POSTGRES_PASSWORD=bcelp_password
POSTGRES_DB=bcelp_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

DATABASE_URL=postgresql+psycopg2://bcelp_user:bcelp_password@postgres:5432/bcelp_db

JWT_SECRET_KEY=your-secret-key
JWT_ALGORITHM=HS256
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=60
